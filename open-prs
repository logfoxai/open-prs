#!/usr/bin/env python3

"""Live TUI dashboard for all open PRs across a GitHub org.

Usage:
    open-prs <org>                  Full-screen TUI dashboard (default)
    open-prs <org> --once           One-shot print and exit
    open-prs <org> --once --plain   One-shot, no colors/links (for piping or AI usage)

Shows open PRs with CI status and recently merged PRs with post-merge
workflow status. Successful deploys fade after 15 min and failures stay
on screen until resolved.

PR titles are clickable via OSC 8 hyperlinks (iTerm2, VS Code, etc.).
Requires: gh (GitHub CLI), authenticated.
"""

from __future__ import annotations

import json
import re
import select
import signal
import shutil
import subprocess
import sys
import termios
import threading
import time
import tty
from concurrent.futures import ThreadPoolExecutor
from datetime import datetime, timedelta, timezone

# ── ANSI & terminal control ─────────────────────────────────────────────────

BOLD = "\033[1m"
DIM = "\033[2m"
RESET = "\033[0m"
CYAN = "\033[36m"
GREEN = "\033[32m"
YELLOW = "\033[33m"
RED = "\033[31m"
WHITE = "\033[37m"
BG_RED = "\033[41m"
BG_GREEN = "\033[42m"
BG_YELLOW = "\033[43m"
BG_MAGENTA = "\033[45m"

HIDE_CURSOR = "\033[?25l"
SHOW_CURSOR = "\033[?25h"
ALT_SCREEN_ON = "\033[?1049h"
ALT_SCREEN_OFF = "\033[?1049l"
CURSOR_HOME = "\033[H"
CLEAR_BELOW = "\033[J"
CLEAR_LINE = "\033[K"
MOVE_TO_ROW = "\033[{row};1H"
SET_TITLE = "\033]0;{title}\007"

# ── configuration ────────────────────────────────────────────────────────────

POLL_SECONDS = 60
DEPLOY_FADE_SECONDS = 15 * 60
MERGED_LOOKBACK_HOURS = 4
TWO_COL_MIN_WIDTH = 100
AD_URL = "https://app.logfox.ai"
AD_TEXT = "🦊 Logfox — Sniff out issues. AI-powered log observability →"

# ── GraphQL ──────────────────────────────────────────────────────────────────

GRAPHQL_QUERY = """\
{{
  open: search(query: "org:{org} is:pr is:open", type: ISSUE, first: 100) {{
    nodes {{
      ... on PullRequest {{
        title url number mergeable headRefName
        author {{ login }}
        createdAt
        repository {{ name owner {{ login }} }}
        commits(last: 1) {{
          nodes {{ commit {{
            statusCheckRollup {{ state }}
            checkSuites(first: 10) {{
              nodes {{ conclusion workflowRun {{ workflow {{ name }} databaseId runNumber url }} }}
            }}
          }} }}
        }}
      }}
    }}
  }}
  merged: search(query: "org:{org} is:pr is:merged merged:>{cutoff}", type: ISSUE, first: 50) {{
    nodes {{
      ... on PullRequest {{
        title url number headRefName
        author {{ login }}
        mergedAt
        mergeCommit {{
          oid
          checkSuites(first: 20) {{
            nodes {{ status conclusion updatedAt workflowRun {{ workflow {{ name }} databaseId runNumber url }} }}
          }}
        }}
        repository {{ name owner {{ login }} }}
      }}
    }}
  }}
}}"""

# ── badges ───────────────────────────────────────────────────────────────────

CI_BADGES = {
    "SUCCESS":    f"{BG_GREEN}{BOLD}{WHITE} ✓ passed {RESET} ",
    "FAILURE":    f"{BG_RED}{BOLD}{WHITE} ✗ failed {RESET} ",
    "ERROR":      f"{BG_RED}{BOLD}{WHITE} ✗ err {RESET} ",
    "PENDING":    f"{BG_YELLOW}{BOLD}{WHITE} ● running {RESET} ",
    "EXPECTED":   f"{BG_YELLOW}{BOLD}{WHITE} ● running {RESET} ",
    "CONFLICT":   f"{BG_RED}{BOLD}{WHITE} ⚠ conflict {RESET} ",
    None:         f"{DIM}no ci {RESET} ",
}

DEPLOY_BADGES = {
    "success":  f"{BG_GREEN}{BOLD}{WHITE} ✓ deployed {RESET} ",
    "failure":  f"{BG_RED}{BOLD}{WHITE} ✗ failed {RESET} ",
    "running":  f"{BG_YELLOW}{BOLD}{WHITE} ● deploying {RESET} ",
    "queued":   f"{BG_YELLOW}{BOLD}{WHITE} ◦ queued {RESET} ",
    "merged":   f"{BG_MAGENTA}{BOLD}{WHITE} ✓ merged {RESET} ",
}

# ── helpers ──────────────────────────────────────────────────────────────────


def write(s: str) -> None:
    sys.stdout.write(s)
    sys.stdout.flush()


def strip_ansi(s: str) -> str:
    """Remove all ANSI/OSC escape sequences from a string."""
    s = re.sub(r"\033\][^\a]*\a", "", s)
    s = re.sub(r"\033\[[0-9;]*m", "", s)
    return s


def visible_len(s: str) -> int:
    """Length of a string as it appears on screen (strips ANSI/OSC escapes)."""
    return len(strip_ansi(s))


BADGE_WIDTH = max(
    visible_len(b)
    for b in [*CI_BADGES.values(), *DEPLOY_BADGES.values()]
)


def osc8_link(url: str, text: str) -> str:
    """Wrap text in an OSC 8 hyperlink (clickable in modern terminals)."""
    return f"\033]8;;{url}\a{text}\033]8;;\a"


def time_ago(iso: str) -> str:
    """Format an ISO timestamp as a human-readable relative time."""
    delta = datetime.now(timezone.utc) - parse_iso(iso)
    days = delta.days
    if days == 0:
        hours = delta.seconds // 3600
        return f"{delta.seconds // 60}m" if hours == 0 else f"{hours}h"
    return f"{days}d" if days < 30 else f"{days // 30}mo"


def parse_iso(iso: str) -> datetime:
    return datetime.fromisoformat(iso.replace("Z", "+00:00"))


# ── data fetching ────────────────────────────────────────────────────────────


def fetch_prs(org: str) -> tuple[list[dict], list[dict]]:
    """Fetch open and recently merged PRs in a single GraphQL call."""
    cutoff = (
        datetime.now(timezone.utc) - timedelta(hours=MERGED_LOOKBACK_HOURS)
    ).strftime("%Y-%m-%dT%H:%M:%SZ")

    try:
        result = subprocess.run(
            ["gh", "api", "graphql", "-f",
             f"query={GRAPHQL_QUERY.format(org=org, cutoff=cutoff)}"],
            capture_output=True, text=True, check=True,
        )
    except subprocess.CalledProcessError as e:
        err = (e.stderr or e.stdout or str(e)).strip()
        if "auth" in err.lower() or "401" in err or "credentials" in err.lower():
            print("open-prs: GitHub authentication required. Run: gh auth login", file=sys.stderr)
        elif err:
            print(f"open-prs: {err}", file=sys.stderr)
        else:
            print(f"open-prs: gh command failed (exit {e.returncode})", file=sys.stderr)
        sys.exit(1)

    data = json.loads(result.stdout)["data"]

    open_prs = _parse_open_nodes(data["open"]["nodes"])
    merged_prs = _parse_merged_nodes(data["merged"]["nodes"])
    return open_prs, merged_prs


def _parse_open_nodes(nodes: list) -> list[dict]:
    prs = []
    for node in nodes:
        if not node:
            continue
        commit = node["commits"]["nodes"][0]["commit"]
        rollup = commit["statusCheckRollup"]
        suites = commit.get("checkSuites", {}).get("nodes", [])
        failures = _extract_failures(suites, node["repository"])
        ci = rollup["state"] if rollup else None
        if node.get("mergeable") == "CONFLICTING":
            ci = "CONFLICT"
        prs.append({
            "repo": node["repository"]["name"],
            "org": node["repository"]["owner"]["login"],
            "title": node["title"],
            "url": node["url"],
            "author": node["author"]["login"],
            "age": time_ago(node["createdAt"]),
            "branch": node.get("headRefName"),
            "ci": ci,
            "failures": failures,
        })
    prs.sort(key=lambda p: (p["repo"], p["title"]))
    return prs


def _extract_failures(suites: list[dict], repo: dict) -> list[dict]:
    """Extract failed workflow info from checkSuites."""
    failures = []
    for suite in suites:
        if suite.get("conclusion") != "FAILURE":
            continue
        run = suite.get("workflowRun")
        if not run:
            continue
        failures.append({
            "workflow": run["workflow"]["name"] if run.get("workflow") else "CI",
            "run_number": run.get("runNumber"),
            "run_id": run.get("databaseId"),
            "url": run.get("url"),
            "org": repo["owner"]["login"],
            "repo": repo["name"],
        })
    return failures


def _fetch_failed_step(failure: dict) -> str | None:
    """Fetch the failed step name for a single failure via REST API."""
    org = failure.get("org")
    repo = failure.get("repo")
    run_id = failure.get("run_id")
    if not all([org, repo, run_id]):
        return None

    try:
        result = subprocess.run(
            ["gh", "api", f"repos/{org}/{repo}/actions/runs/{run_id}/jobs"],
            capture_output=True, text=True, check=True,
        )
        jobs = json.loads(result.stdout).get("jobs", [])
        for job in jobs:
            if job.get("conclusion") == "failure":
                for step in job.get("steps", []):
                    if step.get("conclusion") == "failure":
                        return step.get("name")
        return None
    except (subprocess.CalledProcessError, json.JSONDecodeError):
        return None


def _fetch_all_failed_steps(failures: list[dict]) -> dict[int, str]:
    """Fetch failed step names for all failures in parallel. Returns {run_id: step_name}."""
    if not failures:
        return {}

    results: dict[int, str] = {}
    with ThreadPoolExecutor(max_workers=4) as pool:
        future_to_run_id = {
            pool.submit(_fetch_failed_step, f): f.get("run_id")
            for f in failures if f.get("run_id")
        }
        for future in future_to_run_id:
            run_id = future_to_run_id[future]
            step_name = future.result()
            if step_name:
                results[run_id] = step_name
    return results


def _parse_merged_nodes(nodes: list) -> list[dict]:
    prs = []
    for node in nodes:
        if not node or not node.get("mergeCommit"):
            continue
        suites = node["mergeCommit"].get("checkSuites", {}).get("nodes", [])
        status, failures = _aggregate_check_suites(suites, node["repository"])
        prs.append({
            "repo": node["repository"]["name"],
            "org": node["repository"]["owner"]["login"],
            "title": node["title"],
            "url": node["url"],
            "author": node["author"]["login"],
            "merged_age": time_ago(node["mergedAt"]),
            "merged_at": node["mergedAt"],
            "branch": node.get("headRefName"),
            "workflow_status": status,
            "failures": failures,
        })
    prs.sort(key=lambda p: (p["repo"], p["title"]))
    return prs


def _aggregate_check_suites(suites: list[dict], repo: dict) -> tuple[dict | None, list[dict]]:
    """Aggregate GraphQL checkSuites into a single workflow status and failures list."""
    if not suites:
        return None, []

    statuses = [s["status"] for s in suites]
    failures = _extract_failures(suites, repo)

    if "IN_PROGRESS" in statuses:
        return {"status": "running", "completed_at": None}, failures
    if any(s in ("QUEUED", "WAITING", "REQUESTED", "PENDING") for s in statuses):
        return {"status": "queued", "completed_at": None}, failures
    if not all(s == "COMPLETED" for s in statuses):
        return {"status": "running", "completed_at": None}, failures

    completed_at = max(parse_iso(s["updatedAt"]) for s in suites)
    has_failure = any(s.get("conclusion") == "FAILURE" for s in suites)
    return {
        "status": "failure" if has_failure else "success",
        "completed_at": completed_at,
    }, failures


def build_deployments(
    merged_prs: list[dict],
    failed_cache: dict[str, dict],
) -> list[dict]:
    """Build the list of merged PRs that should be displayed.

    Workflow status is already embedded in each PR from the GraphQL query.
    Mutates failed_cache so failures persist across refreshes in watch mode.
    Failed deploys that fall outside the GraphQL lookback window are kept
    visible via the cache until they succeed or are dismissed.
    """
    now = datetime.now(timezone.utc)
    seen_urls: set[str] = set()
    deployments: list[dict] = []

    for pr in merged_prs:
        seen_urls.add(pr["url"])
        deployment = _resolve_deployment(pr, pr["workflow_status"], now, failed_cache)
        if deployment:
            deployments.append(deployment)

    for url, cached in list(failed_cache.items()):
        if url not in seen_urls:
            deployments.append({**cached["pr"], "deploy": "failure", "failures": cached["pr"].get("failures", [])})

    deployments.sort(key=lambda d: (d["repo"], d["title"]))
    return deployments


def _resolve_deployment(
    pr: dict,
    ws: dict | None,
    now: datetime,
    failed_cache: dict[str, dict],
) -> dict | None:
    """Check a single merged PR's workflow status and return it if visible."""
    url = pr["url"]

    if ws is None:
        failed_cache.pop(url, None)
        elapsed = (now - parse_iso(pr["merged_at"])).total_seconds()
        if elapsed < DEPLOY_FADE_SECONDS:
            return {**pr, "deploy": "merged"}
        return None

    if ws["status"] == "failure":
        failed_cache[url] = {"pr": pr}
        return {**pr, "deploy": "failure", "failures": pr.get("failures", [])}

    failed_cache.pop(url, None)

    if ws["status"] in ("running", "queued"):
        return {**pr, "deploy": ws["status"]}

    if ws["completed_at"]:
        elapsed = (now - ws["completed_at"]).total_seconds()
        if elapsed < DEPLOY_FADE_SECONDS:
            return {**pr, "deploy": "success"}

    return None


# ── rendering ────────────────────────────────────────────────────────────────


def _render_pr(item: dict, width: int) -> list[str]:
    """Render a PR as 2-3 lines: badge + clickable title, metadata, and optionally failure details."""
    is_deploy = bool(item.get("deploy"))

    if is_deploy:
        badge = DEPLOY_BADGES.get(item["deploy"], DEPLOY_BADGES["running"])
        merged_label = (
            f"{RED}merged{RESET}{DIM}" if item["deploy"] == "failure"
            else "merged"
        )
        base_meta = f"{item['author']} · {merged_label} {item['merged_age']} ago"
    else:
        badge = CI_BADGES.get(item.get("ci"), CI_BADGES[None])
        base_meta = f"{item['author']} · {item['age']} ago"

    # Build meta line with branch (truncated if needed, min 10 chars for branch)
    meta = base_meta
    if item.get("branch"):
        branch_sep = " · "
        available = width - BADGE_WIDTH - 2  # space after badge area
        base_len = visible_len(base_meta)
        branch = item["branch"]
        branch_len = len(branch)
        total_len = base_len + len(branch_sep) + branch_len

        if total_len <= available:
            meta = f"{base_meta}{branch_sep}{branch}"
        elif available > base_len + len(branch_sep) + 10:
            # Truncate branch to fit, keeping at least 10 chars
            max_branch = available - base_len - len(branch_sep)
            if max_branch >= 10:
                truncated = branch[:max_branch - 1] + "…" if branch_len > max_branch else branch
                meta = f"{base_meta}{branch_sep}{truncated}"

    pad = " " * (BADGE_WIDTH - visible_len(badge))

    title = item["title"]
    pr_num = item["url"].rstrip("/").split("/")[-1]
    pr_suffix = f"(#{pr_num})"
    max_title = width - BADGE_WIDTH - 4 - len(pr_suffix) - 1

    if len(title) > max(max_title, 12):
        title = title[: max(max_title - 1, 11)] + "…"
    title_with_num = f"{title} {pr_suffix}"

    # Meta/failure lines align with title text (after badge area)
    meta_indent = " " * BADGE_WIDTH
    lines = [
        f"  {badge}{pad}{osc8_link(item['url'], f'{GREEN}{title_with_num}{RESET}')}",
        f"  {meta_indent}{DIM}{meta}{RESET}",
    ]

    is_failure = (is_deploy and item["deploy"] == "failure") or (not is_deploy and item.get("ci") == "FAILURE")
    if is_failure:
        failure_line = _render_failure_line(item.get("failures", []), width - BADGE_WIDTH - 4)
        if failure_line:
            lines.append(f"  {meta_indent}{DIM}{failure_line}{RESET}")

    return lines


def _render_failure_line(failures: list[dict], max_width: int) -> str:
    """Render failure details as a dim line with clickable workflow link."""
    if not failures:
        return ""

    f = failures[0]
    workflow = f.get("workflow", "CI")
    url = f.get("url", "")
    step = f.get("step_name")

    if step:
        available = max_width - len(workflow) - 3
        if available > 5:
            step_display = step[:available - 1] + "…" if len(step) > available else step
            result_text = f"{workflow} · {step_display}"
        else:
            result_text = workflow
    else:
        result_text = workflow

    if url:
        return osc8_link(url, result_text)
    return result_text


def _build_header(org: str, n_open: int, n_merged: int, watch: bool, show_merged: bool = True) -> str:
    counts = f"{n_open} open"
    if n_merged and show_merged:
        counts += f", {n_merged} merged"

    header = f"{BOLD}{CYAN}PRs{RESET} {DIM}({org}, {counts})"
    if watch:
        header += f"  ·  {RESET}{BOLD}r{RESET}{DIM} refresh  {RESET}{BOLD}m{RESET}{DIM} {'hide' if show_merged else 'show'} merged  {RESET}{BOLD}q{RESET}{DIM} quit"
    return header + RESET


def _group_items(open_prs: list[dict], deployments: list[dict]) -> dict[str, list[dict]]:
    """Merge open and deployed PRs into repo-keyed groups, open first."""
    all_items = [
        {**pr, "kind": "open"} for pr in open_prs
    ] + [
        {**d, "kind": "merged"} for d in deployments
    ]

    groups: dict[str, list[dict]] = {}
    for item in all_items:
        groups.setdefault(item["repo"], []).append(item)
    for items in groups.values():
        items.sort(key=lambda x: (0 if x["kind"] == "open" else 1, x["title"]))

    return groups


def _layout_two_columns(blocks: list[list[str]], col_width: int) -> list[str]:
    """Interleave blocks into 2 balanced columns separated by a │."""
    left: list[str] = []
    right: list[str] = []
    lc = rc = 0

    for block in blocks:
        target = left if lc <= rc else right
        if target:
            target.append("")
        target.extend(block)
        if target is left:
            lc += len(block) + (1 if lc else 0)
        else:
            rc += len(block) + (1 if rc else 0)

    max_h = max(len(left), len(right))
    left.extend([""] * (max_h - len(left)))
    right.extend([""] * (max_h - len(right)))

    sep = f" {DIM}│{RESET} "
    return [
        lc + " " * max(col_width - visible_len(lc), 0) + sep + rc
        for lc, rc in zip(left, right)
    ]


def render(
    open_prs: list[dict],
    deployments: list[dict],
    org: str,
    watch: bool,
    plain: bool = False,
    max_rows: int | None = None,
    show_merged: bool = True,
) -> str:
    cols, rows = shutil.get_terminal_size((80, 24))
    visible_deployments = deployments if show_merged else []
    header = _build_header(org, len(open_prs), len(deployments), watch, show_merged)

    groups = _group_items(open_prs, visible_deployments)
    if not groups:
        return f"{header}\n\n  {DIM}No PRs.{RESET}\n"

    num_groups = len(groups)
    all_items = [item for g in groups.values() for item in g]
    failure_count = sum(
        1 for item in all_items
        if (item.get("deploy") == "failure") or (item.get("ci") == "FAILURE")
    )
    single_col_lines = 2 + num_groups * 2 + len(all_items) * 2 + failure_count
    effective_rows = max_rows if max_rows else rows
    use_two_cols = not plain and cols >= TWO_COL_MIN_WIDTH and single_col_lines > effective_rows
    col_width = (cols - 3) // 2 if use_two_cols else cols

    blocks: list[list[str]] = []
    for repo in sorted(groups):
        lines = [f"  {BOLD}{YELLOW}{repo}{RESET}"]
        for item in groups[repo]:
            lines.extend(_render_pr(item, col_width))
        blocks.append(lines)

    if use_two_cols:
        body = _layout_two_columns(blocks, col_width)
        all_lines = [header, ""] + body
    else:
        all_lines = [header]
        for block in blocks:
            all_lines.append("")
            all_lines.extend(block)

    if max_rows and len(all_lines) > max_rows:
        all_lines = all_lines[:max_rows - 1] + [f"  {DIM}… +{len(all_lines) - max_rows + 1} more{RESET}"]

    return "\n".join(all_lines)


# ── run modes ────────────────────────────────────────────────────────────────


def _render_ad_bar(cols: int) -> str:
    """Render a subtle ad bar for the bottom of the screen."""
    link = osc8_link(AD_URL, f"{DIM}{AD_TEXT}{RESET}")
    pad = " " * max(cols - visible_len(f"  {AD_TEXT}  "), 0)
    return f"{DIM}{'─' * cols}{RESET}\n  {link}{pad}"


def _show_loading(msg: str) -> None:
    write(f"\r{DIM}{msg}…{RESET}")


def _show_loading_alt(msg: str) -> None:
    """Loading indicator for the alternate screen buffer."""
    write(f"{CURSOR_HOME}{DIM}{msg}…{RESET}{CLEAR_LINE}")


def _fetch_all(org: str, failed_cache: dict, loading_fn) -> tuple:
    """Fetch PRs and deployments, calling loading_fn for feedback."""
    loading_fn("Fetching PRs")
    open_prs, merged_prs = fetch_prs(org)
    deployments = build_deployments(merged_prs, failed_cache)
    return open_prs, deployments


def run_once(org: str, plain: bool = False) -> None:
    loading_fn = (lambda msg: None) if plain else _show_loading
    open_prs, deployments = _fetch_all(org, {}, loading_fn)
    if not plain:
        write(f"\r{CLEAR_LINE}")
    output = render(open_prs, deployments, org, watch=False, plain=plain)
    if plain:
        output = strip_ansi(output)
    print(output)


def _wait_for_key(timeout: float) -> str | None:
    """Wait up to timeout seconds for a keypress in cbreak mode."""
    deadline = time.monotonic() + timeout
    while True:
        remaining = deadline - time.monotonic()
        if remaining <= 0:
            return None
        ready, _, _ = select.select([sys.stdin], [], [], min(remaining, 0.25))
        if ready:
            return sys.stdin.read(1)


def _collect_all_failures(open_prs: list[dict], deployments: list[dict]) -> list[dict]:
    """Collect all failures from open PRs and deployments for step name fetching."""
    failures = []
    for pr in open_prs:
        failures.extend(pr.get("failures", []))
    for d in deployments:
        failures.extend(d.get("failures", []))
    return failures


def _apply_step_names(items: list[dict], step_names: dict[int, str]) -> None:
    """Apply fetched step names to failure dicts in-place."""
    for item in items:
        for f in item.get("failures", []):
            run_id = f.get("run_id")
            if run_id and run_id in step_names:
                f["step_name"] = step_names[run_id]


def run_watch(org: str) -> None:
    old_settings = termios.tcgetattr(sys.stdin)
    failed_cache: dict[str, dict] = {}
    step_names_cache: dict[int, str] = {}
    current_state: dict = {"open_prs": [], "deployments": []}
    show_merged = True

    write(SET_TITLE.format(title=f"open-prs — {org}"))
    write(f"{ALT_SCREEN_ON}{HIDE_CURSOR}")
    try:
        tty.setcbreak(sys.stdin.fileno())

        def _draw(open_prs, deployments, merged_visible=None):
            current_state["open_prs"] = open_prs
            current_state["deployments"] = deployments
            if merged_visible is not None:
                nonlocal show_merged
                show_merged = merged_visible
            cols, rows = shutil.get_terminal_size((80, 24))
            output = render(open_prs, deployments, org, watch=True, max_rows=rows - 2, show_merged=show_merged)
            ad = _render_ad_bar(cols)
            write(f"{CURSOR_HOME}{CLEAR_BELOW}{output}{MOVE_TO_ROW.format(row=rows - 1)}{ad}")

        def _on_resize(signum, frame):
            _draw(current_state["open_prs"], current_state["deployments"])

        signal.signal(signal.SIGWINCH, _on_resize)

        while True:
            open_prs, deployments = _fetch_all(org, failed_cache, _show_loading_alt)

            _apply_step_names(open_prs, step_names_cache)
            _apply_step_names(deployments, step_names_cache)
            _draw(open_prs, deployments)

            all_failures = _collect_all_failures(open_prs, deployments)
            new_failures = [f for f in all_failures if f.get("run_id") and f["run_id"] not in step_names_cache]

            if new_failures:
                def fetch_and_redraw():
                    new_steps = _fetch_all_failed_steps(new_failures)
                    if new_steps:
                        step_names_cache.update(new_steps)
                        _apply_step_names(open_prs, step_names_cache)
                        _apply_step_names(deployments, step_names_cache)
                        _draw(open_prs, deployments)

                threading.Thread(target=fetch_and_redraw, daemon=True).start()

            key = _wait_for_key(POLL_SECONDS)
            if key in ("q", "\x03"):
                break
            elif key == "m":
                _draw(current_state["open_prs"], current_state["deployments"], merged_visible=not show_merged)
    except KeyboardInterrupt:
        pass
    finally:
        termios.tcsetattr(sys.stdin, termios.TCSADRAIN, old_settings)
        write(f"{SHOW_CURSOR}{ALT_SCREEN_OFF}")


def main() -> None:
    args = [a for a in sys.argv[1:] if not a.startswith("-")]
    flags = {a for a in sys.argv[1:] if a.startswith("-")}

    if not args or "--help" in flags or "-h" in flags:
        print("Usage: open-prs <org> [--once [--plain]]", file=sys.stderr)
        sys.exit(0 if ("--help" in flags or "-h" in flags) else 1)

    org = args[0]

    if "--once" in flags:
        run_once(org, plain="--plain" in flags)
    else:
        run_watch(org)


if __name__ == "__main__":
    main()
